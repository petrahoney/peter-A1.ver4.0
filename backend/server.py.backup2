@app.get("/api/")
async def root() -> dict[str, Any]:
    return {
        "name": "PETER AI",
        "version": "4.0.0",
        "tagline": "Intelligence, Elevated.",
        "archetype": "The Luxury Strategist",
        "status": "online",
    }


@app.get("/api/tiers")
